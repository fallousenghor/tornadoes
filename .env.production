# Frontend Production Environment for Vercel
# These variables will be set in Vercel dashboard

# API Configuration - UPDATE THIS WITH YOUR RENDER BACKEND URL
VITE_API_URL=https://<your-backend-url>.onrender.com/api/v1

# Application Info
VITE_APP_NAME=Tornadoes Job ERP
VITE_APP_VERSION=2.0.0

# Feature Flags
VITE_ENABLE_AI=false
VITE_ENABLE_ADVANCED_REPORTING=true
