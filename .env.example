# .env.example - Tornadoes Job ERP Frontend
# Copiez ce fichier dans .env et remplissez les valeurs

# -------------------------------------------------------------------
# API CONFIGURATION
# -------------------------------------------------------------------
# URL de l'API backend
VITE_API_URL=http://localhost:8080/api/v1

# -------------------------------------------------------------------
# APPLICATION INFO
# -------------------------------------------------------------------
VITE_APP_NAME=Tornadoes Job ERP
VITE_APP_VERSION=2.0.0

# -------------------------------------------------------------------
# FEATURE FLAGS (Optionnel)
# -------------------------------------------------------------------
# Activer/désactiver des fonctionnalités expérimentales
VITE_ENABLE_AI=false
VITE_ENABLE_ADVANCED_REPORTING=true

# -------------------------------------------------------------------
# AUTHENTICATION (Optionnel)
# -------------------------------------------------------------------
# Durée de session en minutes (défaut: 30)
# VITE_SESSION_TIMEOUT=30

# -------------------------------------------------------------------
# UI CONFIGURATION (Optionnel)
# -------------------------------------------------------------------
# Thème par défaut: light | dark
# VITE_DEFAULT_THEME=light

# Langue par défaut: fr | en
# VITE_DEFAULT_LANG=fr
